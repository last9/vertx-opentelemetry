# Init container image for Vert.x 3 + RxJava2 operator-based injection.
#
# This image is used by the l9-otel-operator vertx-webhook to copy the agent JAR
# into a shared emptyDir volume. The webhook then sets:
#   JAVA_TOOL_OPTIONS=-javaagent:/vertx-otel/vertx-otel.jar
#
# Note: Vert.x 3 has no VertxTracer SPI. The agent initializes the OTel SDK and
# JVM metrics automatically, but HTTP spans require TracedRouter in application code.
#
# Usage in pod spec (injected automatically by the webhook):
#
#   initContainers:
#   - name: vertx-otel-init
#     image: ghcr.io/last9/vertx-otel-java3:2.1.0
#     command: ["cp", "/vertx-otel.jar", "/vertx-otel/vertx-otel.jar"]
#     volumeMounts:
#     - name: vertx-otel
#       mountPath: /vertx-otel
#
# Build: docker build -f Dockerfile.java3-agent --build-arg VERSION=2.1.0 -t ghcr.io/last9/vertx-otel-java3:2.1.0 .
# (run after: mvn clean package -pl vertx3-rxjava2-otel-autoconfigure -am -DskipTests)

FROM scratch
ARG VERSION
COPY vertx3-rxjava2-otel-autoconfigure/target/vertx3-rxjava2-otel-autoconfigure-${VERSION}.jar \
     /vertx-otel.jar
